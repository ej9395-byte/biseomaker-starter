# 비서메이커 스타터 환경변수
# SETUP.md 실행 시 Claude가 자동으로 채워줍니다

# 텔레그램
TELEGRAM_BOT_TOKEN=           # @BotFather에서 발급
TELEGRAM_CHAT_ID=             # @userinfobot으로 확인

# Anthropic API
ANTHROPIC_API_KEY=            # console.anthropic.com에서 발급

# 디렉토리 경로
OBSIDIAN_VAULT_DIR=           # 옵시디언 볼트 폴더 절대경로
OBSIDIAN_INBOX_DIR=           # 옵시디언 Inbox 폴더 (보통 볼트/Inbox)
LOG_DIR=                      # 대화 기록/업무일지 폴더
WORKSPACE_DIR=                # 이 레포 절대경로
CLAUDE_BIN=                   # claude CLI 경로 (예: /usr/local/bin/claude)

# 사업 정보 (SETUP.md 실행 시 자동 생성)
BUSINESS_NAME=                # 상호명
BUSINESS_DOMAIN=              # 업종
BOT_NAME=                     # AI 파트너 이름
OWNER_NAME=                   # 대표님 성함
MONTHLY_GOAL=                 # 이번 달 목표

# 암묵지 도메인 (쉼표 구분)
DOMAINS=sales,operations,marketing,customer,product

# 노션 (선택)
NOTION_TOKEN=

# Claude 모델 설정 (기본값 권장)
MODEL_COLLECT=claude-haiku-4-5-20251001
MODEL_LEARN=claude-sonnet-4-6
MODEL_SYNTHESIZE=claude-opus-4-7
